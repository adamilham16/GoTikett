APP_NAME=GoTiket
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_PORT=8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=gotiket
DB_USERNAME=gotiket_user
DB_PASSWORD=gotiket_pass
DB_ROOT_PASSWORD=root_secret
DB_PORT_EXPOSE=3306

BROADCAST_DRIVER=log
CACHE_STORE=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# phpMyAdmin (aktifkan dengan --profile tools)
PMA_PORT=8080
